{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "@loykin/resourcekit": ["../src/index.ts"],
      "@loykin/resourcekit/react": ["../src/react/index.ts"],
      "@loykin/resourcekit/adapters": ["../src/adapters/index.ts"],
      "@loykin/resourcekit/adapters/designkit": ["../src/adapters/designkit/index.ts"],
      "@loykin/resourcekit/adapters/gridkit": ["../src/adapters/gridkit/index.ts"],
      "@loykin/resourcekit/adapters/chartkit": ["../src/adapters/chartkit/index.ts"],
      "@loykin/resourcekit/adapters/basekit": ["../src/adapters/basekit/index.ts"],
      "@loykin/resourcekit/adapters/datasourcekit": ["../src/adapters/datasourcekit/index.ts"]
    }
  },
  "include": ["src", "server"]
}
