{
  "compilerOptions": {
    "target":             "ES2020",
    "lib":                ["ES2020", "DOM", "DOM.Iterable"],
    "module":             "ESNext",
    "moduleResolution":   "bundler",
    "jsx":                "react-jsx",
    "strict":             true,
    "declaration":        true,
    "declarationMap":     true,
    "sourceMap":          true,
    "esModuleInterop":    true,
    "skipLibCheck":       true,
    "isolatedModules":    true,
    "ignoreDeprecations": "6.0"
  },
  "include":  ["src"],
  "exclude":  ["node_modules", "dist"]
}
