{
  "apiVersion": "loykin.dev/v1alpha1",
  "kind": "ListDetail",
  "metadata": { "name": "scenario-customer-crm" },
  "spec": {
    "listWidth": 340,
    "selectionVariable": "customerId",
    "variables": [
      { "name": "customerId", "type": "string", "default": "1", "persist": "url" },
      { "name": "status", "type": "string", "default": "active" }
    ]
  },
  "slots": [
    {
      "name": "topBar",
      "items": [
        {
          "apiVersion": "loykin.dev/v1alpha1",
          "kind": "PageTopBar",
          "spec": { "left": "Customers", "height": "76px" },
          "slots": [
            {
              "name": "right",
              "items": [
                {
                  "apiVersion": "loykin.dev/v1alpha1",
                  "kind": "FilterControl",
                  "spec": {
                    "valueRef": "variables.status",
                    "config": {
                      "key": "status",
                      "type": "select",
                      "label": "Status",
                      "options": [
                        { "label": "Active", "value": "active" },
                        { "label": "Prospect", "value": "prospect" }
                      ],
                      "behavior": { "clearable": true }
                    },
                    "events": { "change": { "kind": "setVariable", "variable": "status", "from": "value" } }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "list",
      "items": [
        {
          "apiVersion": "loykin.dev/v1alpha1",
          "kind": "SelectableList",
          "spec": {
            "data": {
              "source": "datasource",
              "datasourceUid": "crm",
              "query": { "status": "${status}" }
            },
            "idField": "id",
            "selectedRef": "variables.customerId",
            "primary": { "field": "name" },
            "secondary": [
              { "field": "status", "label": "Status" },
              { "field": "revenue", "label": "Revenue" }
            ],
            "events": { "select": { "kind": "setVariable", "variable": "customerId", "from": "row.id" } }
          }
        }
      ]
    },
    {
      "name": "detail",
      "items": [
        {
          "apiVersion": "loykin.dev/v1alpha1",
          "kind": "RecordScope",
          "spec": {
            "data": {
              "source": "datasource",
              "datasourceUid": "crm",
              "query": { "id": "${customerId}" }
            }
          },
          "slots": [
            {
              "items": [
                {
                  "apiVersion": "loykin.dev/v1alpha1",
                  "kind": "DataBody",
                  "spec": { "title": "Customer detail", "description": "Selected customer profile and revenue trend." },
                  "slots": [
                    {
                      "items": [
                        {
                          "apiVersion": "loykin.dev/v1alpha1",
                          "kind": "DataBodyGroup",
                          "spec": { "title": "Profile", "layout": "inline", "variant": "plain" },
                          "slots": [
                            {
                              "items": [
                                {
                                  "apiVersion": "loykin.dev/v1alpha1",
                                  "kind": "ObjectFields",
                                  "spec": {
                                    "fields": [
                                      { "label": "Name", "path": "name" },
                                      { "label": "Status", "path": "status", "display": "badge" },
                                      { "label": "Revenue", "path": "revenue" }
                                    ]
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ,
                        {
                          "apiVersion": "loykin.dev/v1alpha1",
                          "kind": "ChartView",
                          "spec": {
                            "chart": {
                              "type": "bar",
                              "height": 220,
                              "categories": ["Active", "Prospect"],
                              "series": [{ "label": "Revenue", "color": "#2563eb", "values": [140, 118] }]
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
